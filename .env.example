# Sanity (free tier) — https://sanity.io/manage
NEXT_PUBLIC_SANITY_PROJECT_ID=
NEXT_PUBLIC_SANITY_DATASET=production

# Optional — site canonical URL for sitemap/Open Graph
NEXT_PUBLIC_SITE_URL=https://your-domain.example

# Contact form → Google Sheets (service account JSON key from Google Cloud)
# Spreadsheet URL id: docs.google.com/spreadsheets/d/<THIS_PART>/edit
# Share sheet with the service account email as Editor (from JSON: client_email)
GOOGLE_SHEETS_SPREADSHEET_ID=
GOOGLE_SERVICE_ACCOUNT_EMAIL=
# Private key from JSON, quoted; paste with real newlines or use \\n between lines in .env.local
GOOGLE_PRIVATE_KEY=""
# Sheet tab name (default Sheet1)
GOOGLE_SHEETS_TAB=Sheet1
