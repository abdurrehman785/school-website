# Sanity (free tier) — https://sanity.io/manage
NEXT_PUBLIC_SANITY_PROJECT_ID=
NEXT_PUBLIC_SANITY_DATASET=production

# Optional — site canonical URL for sitemap/Open Graph
NEXT_PUBLIC_SITE_URL=https://your-domain.example

# --- Contact form → Google Sheets (required on Vercel for /api/contact) ---
# Spreadsheet id from URL: docs.google.com/spreadsheets/d/<THIS>/edit
GOOGLE_SHEETS_SPREADSHEET_ID=

# RECOMMENDED on Vercel (one variable, no newline issues):
# 1) Download service account JSON from Google Cloud.
# 2) Base64-encode the whole file (PowerShell):
#    [Convert]::ToBase64String([IO.File]::ReadAllBytes("path\to\key.json"))
# 3) Paste result into Vercel as GOOGLE_SERVICE_ACCOUNT_KEY_BASE64
GOOGLE_SERVICE_ACCOUNT_KEY_BASE64=

# OR paste minified JSON on one line (less reliable with quotes):
# GOOGLE_SERVICE_ACCOUNT_JSON={"type":"service_account",...}

# OR separate fields (works best in .env.local):
# GOOGLE_SERVICE_ACCOUNT_EMAIL=...@....iam.gserviceaccount.com
# GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

GOOGLE_SHEETS_TAB=Sheet1
